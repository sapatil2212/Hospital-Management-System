generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Hospital {
  id                    String                 @id @default(uuid())
  name                  String
  email                 String                 @unique
  mobile                String
  isVerified            Boolean                @default(false)
  createdAt             DateTime               @default(now())
  beds                  Bed[]
  bedAllocations        BedAllocation[]
  departments           Department[]
  doctors               Doctor[]
  settings              HospitalSettings?
  inventoryItems        InventoryItem[]
  pricing               Pricing[]
  procedures            Procedure[]
  rooms                 Room[]
  staffMembers          Staff[]
  subDepartments        SubDepartment[]
  users                 User[]
  wards                 Ward[]
  patients              Patient[]
  appointments          Appointment[]
  followUps             FollowUp[]
  procedureRecords      ProcedureRecord[]
  prescriptions         Prescription[]
  prescriptionWorkflows PrescriptionWorkflow[]
  bills                 Bill[]
  billItems             BillItem[]
  payments              Payment[]
  expenses              Expense[]
  revenues              Revenue[]
  financeDepartment     FinanceDepartment?
  serviceItems          ServiceItem[]
  visits                Visit[]
  doctorActions         DoctorAction[]
  workflowTasks         WorkflowTask[]
  stockBatches          StockBatch[]
  stockMovements        StockMovement[]
  suppliers             Supplier[]
  purchases             Purchase[]
  purchaseItems         PurchaseItem[]
}

model User {
  id            String         @id @default(uuid())
  hospitalId    String
  name          String
  email         String         @unique
  password      String
  role          Role
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  profilePhoto  String?        @db.Text
  doctor             Doctor?
  sessions           Session[]
  staff              Staff?
  subDepartment      SubDepartment?
  financeDepartment  FinanceDepartment?
  hospital           Hospital       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([email, hospitalId])
}

model OTP {
  id        String   @id @default(uuid())
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model HospitalSettings {
  id             String   @id @default(uuid())
  hospitalId     String   @unique
  hospitalName   String
  logo           String?
  address        String?  @db.Text
  phone          String?
  email          String?
  website        String?
  timezone       String   @default("Asia/Kolkata")
  currency       String   @default("INR")
  gstNumber      String?
  registrationNo String?
  
  // Letterhead settings
  letterhead     String?  @db.Text  // URL or base64 of the image/pdf
  letterheadType String?  @default("IMAGE") // IMAGE, PDF
  letterheadSize String?  @default("A4")    // A4, A5, Letter

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  hospital       Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
}

model Department {
  id                String          @id @default(uuid())
  hospitalId        String
  name              String
  code              String
  description       String?
  type              DepartmentType  @default(OPD)
  isActive          Boolean         @default(true)
  consultationFee   Float?
  allowAppointments Boolean         @default(true)
  isIPD             Boolean         @default(false)
  hodDoctorId       String?
  location          String?
  billingCode       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  hodDoctor         Doctor?         @relation("DepartmentHOD", fields: [hodDoctorId], references: [id])
  hospital          Hospital        @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  doctors           Doctor[]        @relation("DepartmentDoctors")
  pricing           Pricing[]
  staff             Staff[]
  subDepartments    SubDepartment[]
  appointments      Appointment[]

  @@unique([hospitalId, code])
  @@index([hospitalId])
  @@index([hodDoctorId], map: "Department_hodDoctorId_fkey")
}

model SubDepartment {
  id              String            @id @default(uuid())
  hospitalId      String
  name            String
  type            SubDepartmentType
  departmentId    String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  code            String?
  color           String?           @default("#3b82f6")
  credentialsSent Boolean           @default(false)
  description     String?           @db.Text
  flow            String?           @db.Text
  hodEmail        String?
  hodName         String?
  hodPhone        String?
  hodStaffId      String?
  loginEmail      String?           @unique
  userId          String?           @unique
  procedures            Procedure[]
  department            Department?       @relation(fields: [departmentId], references: [id])
  hospital              Hospital          @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  user                  User?             @relation(fields: [userId], references: [id])
  appointments          Appointment[]
  procedureRecords      ProcedureRecord[]
  prescriptionWorkflows PrescriptionWorkflow[]

  @@unique([hospitalId, name, type])
  @@index([hospitalId])
  @@index([departmentId], map: "SubDepartment_departmentId_fkey")
}

model Procedure {
  id              String        @id @default(uuid())
  hospitalId      String
  subDepartmentId String
  name            String
  description     String?       @db.Text
  type            ProcedureType @default(OTHER)
  fee             Float?
  duration        Int?
  sequence        Int           @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  hospital         Hospital          @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  subDepartment    SubDepartment     @relation(fields: [subDepartmentId], references: [id], onDelete: Cascade)
  procedureRecords ProcedureRecord[]

  @@index([hospitalId])
  @@index([subDepartmentId])
  @@index([hospitalId, subDepartmentId])
}

model Doctor {
  id                String                   @id @default(uuid())
  hospitalId        String
  name              String
  email             String
  phone             String?
  specialization    String?
  qualification     String?
  departmentId      String?
  consultationFee   Float                    @default(0)
  isAvailable       Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  experience        Int                      @default(0)
  followUpFee       Float?
  gender            Gender?
  isActive          Boolean                  @default(true)
  profileImage      String?                  @db.Text
  address           String?                  @db.Text
  agreementDoc      String?
  bloodGroup        String?
  credentialsSent   Boolean                  @default(false)
  dateOfBirth       DateTime?
  govtIdCard        String?
  hospitalStamp     String?
  licenseNo         String?
  registrationNo    String?
  signature         String?
  userId            String?                  @unique
  prescriptionSettings String?                @db.Text
  hodOfDepartments  Department[]             @relation("DepartmentHOD")
  department        Department?              @relation("DepartmentDoctors", fields: [departmentId], references: [id])
  hospital          Hospital                 @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  user              User?                    @relation(fields: [userId], references: [id])
  attendance        DoctorAttendance[]
  availability      DoctorAvailability[]
  leaves            DoctorLeave[]
  scheduleTemplates DoctorScheduleTemplate[]
  appointments      Appointment[]
  prescriptions     Prescription[]
  visits            Visit[]

  @@unique([hospitalId, email])
  @@index([hospitalId])
  @@index([hospitalId, departmentId])
  @@index([departmentId], map: "Doctor_departmentId_fkey")
}

model DoctorAvailability {
  id                 String    @id @default(uuid())
  doctorId           String
  day                DayOfWeek
  startTime          String
  endTime            String
  createdAt          DateTime  @default(now())
  hospitalId         String
  isActive           Boolean   @default(true)
  slotDuration       Int       @default(30)
  updatedAt          DateTime  @updatedAt
  breaks             String?   @db.Text
  bufferTime         Int       @default(0)
  generatedSlots     String?   @db.Text
  maxPatientsPerSlot Int       @default(1)
  doctor             Doctor    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, day])
  @@index([doctorId])
  @@index([hospitalId])
}

model DoctorScheduleTemplate {
  id           String   @id @default(uuid())
  hospitalId   String
  doctorId     String?
  name         String
  description  String?
  scheduleData String   @db.Text
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  doctor       Doctor?  @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([doctorId])
}

model DoctorLeave {
  id         String   @id @default(uuid())
  doctorId   String
  hospitalId String
  leaveFrom  DateTime
  leaveTo    DateTime
  reason     String?
  isApproved Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  doctor     Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([doctorId])
  @@index([hospitalId])
  @@index([doctorId, leaveFrom, leaveTo])
}

model DoctorAttendance {
  id         String           @id @default(uuid())
  doctorId   String
  hospitalId String
  date       DateTime         @db.Date
  status     AttendanceStatus @default(ABSENT)
  loginTime  DateTime?
  logoutTime DateTime?
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  doctor     Doctor           @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@unique([doctorId, date])
  @@index([doctorId])
  @@index([hospitalId])
  @@index([date])
}

model Staff {
  id                 String      @id @default(uuid())
  hospitalId         String
  name               String
  email              String
  phone              String?
  role               StaffRole
  departmentId       String?
  salary             Float       @default(0)
  joinDate           DateTime    @default(now())
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  credentialsSent    Boolean     @default(false)
  mustChangePassword Boolean     @default(true)
  password           String?
  permissions        String?     @db.Text
  userId             String?     @unique
  department         Department? @relation(fields: [departmentId], references: [id])
  hospital           Hospital    @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  user               User?       @relation(fields: [userId], references: [id])

  @@unique([hospitalId, email])
  @@index([hospitalId])
  @@index([email])
  @@index([departmentId], map: "Staff_departmentId_fkey")
}

model Ward {
  id          String   @id @default(uuid())
  hospitalId  String
  name        String
  type        WardType
  floor       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?  @db.Text
  beds        Bed[]
  rooms       Room[]
  hospital    Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@unique([hospitalId, name])
  @@index([hospitalId])
}

model Room {
  id          String   @id @default(uuid())
  hospitalId  String
  wardId      String
  roomNumber  String
  roomType    RoomType @default(SHARED)
  capacity    Int      @default(1)
  description String?  @db.Text
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  beds        Bed[]
  hospital    Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  ward        Ward     @relation(fields: [wardId], references: [id], onDelete: Cascade)

  @@unique([wardId, roomNumber])
  @@index([hospitalId])
  @@index([wardId])
}

model Bed {
  id          String          @id @default(uuid())
  hospitalId  String
  wardId      String
  bedNumber   String
  status      BedStatus       @default(AVAILABLE)
  pricePerDay Float           @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  bedType     BedType         @default(NORMAL)
  roomId      String?
  hospital    Hospital        @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  room        Room?           @relation(fields: [roomId], references: [id])
  ward        Ward            @relation(fields: [wardId], references: [id], onDelete: Cascade)
  allocations BedAllocation[]

  @@unique([roomId, bedNumber])
  @@index([hospitalId])
  @@index([wardId])
  @@index([roomId])
  @@index([status])
}

model BedAllocation {
  id                    String           @id @default(uuid())
  hospitalId            String
  bedId                 String
  patientName           String
  patientAge            Int?
  patientGender         String?
  patientPhone          String?
  attendantName         String?
  attendantPhone        String?
  diagnosis             String?          @db.Text
  admittingDoctorName   String?
  admissionDate         DateTime         @default(now())
  expectedDischargeDate DateTime?
  actualDischargeDate   DateTime?
  notes                 String?          @db.Text
  status                AllocationStatus @default(ACTIVE)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  bed                   Bed              @relation(fields: [bedId], references: [id], onDelete: Cascade)
  hospital              Hospital         @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([bedId])
  @@index([status])
  @@index([hospitalId, status])
}

model Pricing {
  id           String      @id @default(uuid())
  hospitalId   String
  name         String
  type         PricingType
  amount       Float
  description  String?
  departmentId String?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  department   Department? @relation(fields: [departmentId], references: [id])
  hospital     Hospital    @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([hospitalId, type])
  @@index([departmentId], map: "Pricing_departmentId_fkey")
}

model InventoryItem {
  id              String          @id @default(uuid())
  hospitalId      String
  name            String
  category        String
  description     String?         @db.Text
  minStock        Int             @default(5)
  unit            String          @default("pcs")
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  maxStock        Int?
  sku             String?
  subCategory     String?
  attachments     String?         @db.Text
  barcode         String?
  billingType     String?
  brandName       String?
  conversion      String?
  discount        Float           @default(0)
  drugSchedule    String?
  genericName     String?
  gst             Float           @default(0)
  hsnCode         String?
  image           String?
  isCritical      Boolean         @default(false)
  isReturnable    Boolean         @default(true)
  itemType        String?
  location        String?
  mrp             Float           @default(0)
  packSize        String?
  preferredVendorId String?
  purchasePrice   Float           @default(0)
  purchaseUnit    String?
  rackNumber      String?
  reorderLevel    Int?
  reorderQty      Int?
  requiresRx      Boolean         @default(false)
  sellingPrice    Float           @default(0)
  tempRequirement String?
  hospital        Hospital        @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  batches         StockBatch[]
  movements       StockMovement[]
  purchaseItems   PurchaseItem[]

  @@unique([hospitalId, name, category])
  @@index([hospitalId])
  @@index([hospitalId, category])
}

enum Role {
  SUPER_ADMIN
  HOSPITAL_ADMIN
  DOCTOR
  RECEPTIONIST
  STAFF
  SUB_DEPT_HEAD
  FINANCE_HEAD
}

enum DepartmentType {
  OPD
  IPD
  DIAGNOSTIC
  SUPPORT
}

enum SubDepartmentType {
  PHARMACY
  PATHOLOGY
  RADIOLOGY
  PROCEDURE
  LABORATORY
  DENTAL
  DERMATOLOGY
  HAIR
  ONCOLOGY
  CARDIOLOGY
  BILLING
  OTHER
}

enum ProcedureType {
  DIAGNOSTIC
  TREATMENT
  CONSULTATION
  SURGERY
  THERAPY
  MEDICATION
  OTHER
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
}

enum StaffRole {
  NURSE
  TECHNICIAN
  PHARMACIST
  RECEPTIONIST
  LAB_TECHNICIAN
  ACCOUNTANT
  ADMIN
  SUPPORT
  OTHER
}

enum WardType {
  GENERAL
  PRIVATE
  SEMI_PRIVATE
  ICU
  NICU
  PICU
  EMERGENCY
  MATERNITY
  ISOLATION
}

enum RoomType {
  SHARED
  PRIVATE
  SEMI_PRIVATE
  ICU
  ISOLATION
}

enum BedType {
  NORMAL
  ICU
  VENTILATOR
  ELECTRIC
  PEDIATRIC
}

enum BedStatus {
  AVAILABLE
  OCCUPIED
  MAINTENANCE
  RESERVED
}

enum AllocationStatus {
  ACTIVE
  DISCHARGED
  TRANSFERRED
}

enum PricingType {
  CONSULTATION
  PROCEDURE
  LAB_TEST
  RADIOLOGY
  PHARMACY
  ROOM_CHARGE
  SURGERY
  OTHER
}

// ─────────────────────────────────────────────────────────────────────────────
// PATIENT / APPOINTMENT / FOLLOW-UP
// ─────────────────────────────────────────────────────────────────────────────

model Patient {
  id               String            @id @default(uuid())
  hospitalId       String
  patientId        String
  name             String
  email            String?
  phone            String
  gender           String?
  dateOfBirth      DateTime?
  bloodGroup       String?
  address          String?           @db.Text
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  hospital         Hospital          @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  followUps        FollowUp[]
  prescriptions    Prescription[]
  bills            Bill[]
  procedureRecords ProcedureRecord[]
  visits           Visit[]

  @@unique([hospitalId, patientId])
  @@unique([hospitalId, phone])
  @@index([hospitalId])
  @@index([hospitalId, phone])
  @@index([hospitalId, name])
}

model Appointment {
  id                 String             @id @default(uuid())
  hospitalId         String
  patientId          String
  doctorId           String
  departmentId       String?
  subDepartmentId    String?
  appointmentDate    DateTime           @db.Date
  timeSlot           String
  type               AppointmentType    @default(OPD)
  status             AppointmentStatus  @default(SCHEDULED)
  consultationFee    Float?
  tokenNumber        Int?
  notes              String?            @db.Text
  subDeptNote        String?            @db.Text
  billingTransferred Boolean            @default(false)
  billingNote        String?            @db.Text
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  hospital           Hospital           @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  patient            Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor             Doctor             @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  department         Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  subDepartment      SubDepartment?     @relation(fields: [subDepartmentId], references: [id], onDelete: SetNull)
  followUps          FollowUp[]
  prescription       Prescription?
  procedureRecords   ProcedureRecord[]

  @@index([hospitalId])
  @@index([patientId])
  @@index([doctorId])
  @@index([hospitalId, appointmentDate])
  @@index([hospitalId, status])
  @@index([doctorId, appointmentDate, timeSlot])
  @@index([subDepartmentId])
}

model FollowUp {
  id             String         @id @default(uuid())
  hospitalId     String
  patientId      String
  appointmentId  String?
  followUpDate   DateTime
  reason         String?        @db.Text
  notes          String?        @db.Text
  status         FollowUpStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  hospital       Hospital       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  patient        Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment    Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([hospitalId])
  @@index([patientId])
  @@index([hospitalId, followUpDate])
  @@index([hospitalId, status])
}

enum AppointmentType {
  OPD
  ONLINE
  FOLLOW_UP
  EMERGENCY
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
  RESCHEDULED
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// PROCEDURE RECORDS
// ─────────────────────────────────────────────────────────────────────────────

model ProcedureRecord {
  id              String                @id @default(uuid())
  hospitalId      String
  subDepartmentId String
  procedureId     String
  patientId       String
  appointmentId   String?
  performedAt     DateTime              @default(now())
  amount          Float
  notes           String?               @db.Text
  status          ProcedureRecordStatus @default(COMPLETED)
  performedBy     String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  hospital        Hospital              @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  subDepartment   SubDepartment         @relation(fields: [subDepartmentId], references: [id], onDelete: Cascade)
  procedure       Procedure             @relation(fields: [procedureId], references: [id], onDelete: Cascade)
  patient         Patient               @relation(fields: [patientId], references: [id], onDelete: Cascade)
  appointment     Appointment?          @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([hospitalId])
  @@index([subDepartmentId])
  @@index([patientId])
  @@index([appointmentId])
  @@index([procedureId])
}

enum ProcedureRecordStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ─────────────────────────────────────────────────────────────────────────────
// PRESCRIPTION / WORKFLOW
// ─────────────────────────────────────────────────────────────────────────────

model Prescription {
  id               String                 @id @default(uuid())
  hospitalId       String
  prescriptionNo   String
  appointmentId    String                 @unique
  patientId        String
  doctorId         String
  vitals           String?                @db.Text
  chiefComplaint   String?                @db.Text
  diagnosis        String?                @db.Text
  icdCodes         String?                @db.Text
  medications      String?                @db.Text
  labTests         String?                @db.Text
  referrals        String?                @db.Text
  advice           String?                @db.Text
  followUpDate     DateTime?
  followUpNotes    String?                @db.Text
  consultationFee  Float?
  aiSuggestions    String?                @db.Text
  status           PrescriptionStatus     @default(DRAFT)
  currentDeptId    String?
  doctorNotes      String?                @db.Text
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  hospital         Hospital               @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  appointment      Appointment            @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patient          Patient                @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor           Doctor                 @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  workflows        PrescriptionWorkflow[]
  bill             Bill?

  @@unique([hospitalId, prescriptionNo])
  @@index([hospitalId])
  @@index([patientId])
  @@index([doctorId])
  @@index([appointmentId])
  @@index([hospitalId, status])
}

model PrescriptionWorkflow {
  id              String         @id @default(uuid())
  hospitalId      String
  prescriptionId  String
  subDepartmentId String
  sequence        Int            @default(0)
  status          WorkflowStatus @default(PENDING)
  notes           String?        @db.Text
  completedAt     DateTime?
  completedBy     String?
  charges         String?        @db.Text
  totalCharge     Float          @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  hospital        Hospital       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  prescription    Prescription   @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)
  subDepartment   SubDepartment  @relation(fields: [subDepartmentId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
  @@index([subDepartmentId])
  @@index([hospitalId])
  @@index([hospitalId, status])
}

enum PrescriptionStatus {
  DRAFT
  COMPLETED
  IN_WORKFLOW
  BILLING_PENDING
  BILLED
  CLOSED
}

enum WorkflowStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// ─────────────────────────────────────────────────────────────────────────────
// BILLING / FINANCE
// ─────────────────────────────────────────────────────────────────────────────

model Bill {
  id             String     @id @default(uuid())
  hospitalId     String
  billNo         String
  prescriptionId String?    @unique
  patientId      String
  visitId        String?
  items          String     @db.Text
  subtotal       Float      @default(0)
  discount       Float      @default(0)
  tax            Float      @default(0)
  total          Float      @default(0)
  paidAmount     Float      @default(0)
  status         BillStatus @default(PENDING)
  paidAt         DateTime?
  paymentMethod  String?
  notes          String?    @db.Text
  isGst          Boolean    @default(false)
  cgst           Float      @default(0)
  sgst           Float      @default(0)
  igst           Float      @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  hospital       Hospital   @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  prescription   Prescription? @relation(fields: [prescriptionId], references: [id], onDelete: SetNull)
  patient        Patient    @relation(fields: [patientId], references: [id], onDelete: Cascade)
  billItems      BillItem[]
  payments       Payment[]

  @@unique([hospitalId, billNo])
  @@index([hospitalId])
  @@index([patientId])
  @@index([hospitalId, status])
  @@index([hospitalId, createdAt])
}

model BillItem {
  id          String       @id @default(uuid())
  hospitalId  String
  billId      String
  type        BillItemType @default(OTHER)
  referenceId String?
  name        String
  quantity    Int          @default(1)
  unitPrice   Float
  amount      Float
  gstPercent  Float        @default(0)
  gstAmount   Float        @default(0)
  createdAt   DateTime     @default(now())
  hospital    Hospital     @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  bill        Bill         @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([hospitalId])
  @@index([hospitalId, type])
}

model Payment {
  id            String        @id @default(uuid())
  hospitalId    String
  billId        String
  amount        Float
  method        PaymentMethod @default(CASH)
  transactionId String?
  status        PaymentStatus @default(SUCCESS)
  notes         String?       @db.Text
  paidAt        DateTime      @default(now())
  createdAt     DateTime      @default(now())
  hospital      Hospital      @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  bill          Bill          @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
  @@index([hospitalId])
  @@index([hospitalId, paidAt])
}

model Expense {
  id          String          @id @default(uuid())
  hospitalId  String
  title       String
  category    ExpenseCategory @default(OTHER)
  amount      Float
  date        DateTime        @db.Date
  description String?         @db.Text
  receipt     String?
  addedBy     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  hospital    Hospital        @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([hospitalId, date])
  @@index([hospitalId, category])
}

model Revenue {
  id            String        @id @default(uuid())
  hospitalId    String
  sourceType    RevenueSource @default(OTHER)
  referenceId   String?
  referenceType String?
  amount        Float
  description   String?
  createdAt     DateTime      @default(now())
  hospital      Hospital      @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([hospitalId, sourceType])
  @@index([hospitalId, createdAt])
}

model FinanceDepartment {
  id              String   @id @default(uuid())
  hospitalId      String   @unique
  name            String   @default("Finance Department")
  hodName         String?
  hodEmail        String?
  hodPhone        String?
  loginEmail      String?  @unique
  userId          String?  @unique
  credentialsSent Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  hospital        Hospital @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

enum BillStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  CANCELLED
}

enum BillItemType {
  CONSULTATION
  PROCEDURE
  LAB_TEST
  BED_CHARGE
  PHARMACY
  OTHER
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  INSURANCE
  CHEQUE
  ONLINE
}

enum PaymentStatus {
  SUCCESS
  FAILED
  PENDING
  REFUNDED
}

enum ExpenseCategory {
  SALARY
  EQUIPMENT
  MAINTENANCE
  UTILITY
  MEDICINE
  HOUSEKEEPING
  MARKETING
  INSURANCE_EXPENSE
  OTHER
}

enum RevenueSource {
  CONSULTATION
  PROCEDURE
  BED_CHARGE
  PHARMACY
  LAB_TEST
  OTHER
}

// ─────────────────────────────────────────────────────────────────────────────
// WORKFLOW ENGINE (Visit / DoctorAction / WorkflowTask / ServiceItem)
// ─────────────────────────────────────────────────────────────────────────────

model ServiceItem {
  id           String         @id @default(uuid())
  hospitalId   String
  name         String
  departmentId String?
  subDeptId    String?
  category     String
  type         String
  cost         Float          @default(0)
  duration     Int            @default(30)
  description  String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  hospital     Hospital       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  workflowTasks WorkflowTask[]

  @@index([hospitalId])
  @@index([hospitalId, type])
}

model Visit {
  id              String          @id @default(uuid())
  hospitalId      String
  patientId       String
  doctorId        String?
  appointmentId   String?
  departmentId    String?
  visitNumber     String
  visitType       VisitType       @default(OPD)
  status          VisitStatus     @default(REGISTERED)
  chiefComplaint  String?         @db.Text
  diagnosis       String?         @db.Text
  notes           String?         @db.Text
  tokenNumber     Int?
  checkinTime     DateTime?
  consultStart    DateTime?
  consultEnd      DateTime?
  completedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  hospital        Hospital        @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  patient         Patient         @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor          Doctor?         @relation(fields: [doctorId], references: [id], onDelete: SetNull)
  doctorActions   DoctorAction[]
  workflowTasks   WorkflowTask[]

  @@unique([hospitalId, visitNumber])
  @@index([hospitalId])
  @@index([patientId])
  @@index([doctorId])
  @@index([hospitalId, status])
  @@index([hospitalId, createdAt])
}

model DoctorAction {
  id            String         @id @default(uuid())
  hospitalId    String
  visitId       String
  actionType    ActionType
  serviceItemId String?
  targetDeptId  String?
  subDeptType   String?
  notes         String?        @db.Text
  payload       String?        @db.Text
  createdAt     DateTime       @default(now())
  hospital      Hospital       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  visit         Visit          @relation(fields: [visitId], references: [id], onDelete: Cascade)
  workflowTask  WorkflowTask?

  @@index([hospitalId])
  @@index([visitId])
}

model WorkflowTask {
  id             String          @id @default(uuid())
  hospitalId     String
  visitId        String
  doctorActionId String?         @unique
  taskType       String
  subDeptType    String?
  serviceItemId  String?
  assignedTo     String?
  status         WorkflowStatus  @default(PENDING)
  notes          String?         @db.Text
  resultNotes    String?         @db.Text
  reportUrl      String?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  hospital       Hospital        @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  visit          Visit           @relation(fields: [visitId], references: [id], onDelete: Cascade)
  doctorAction   DoctorAction?   @relation(fields: [doctorActionId], references: [id], onDelete: SetNull)
  serviceItem    ServiceItem?    @relation(fields: [serviceItemId], references: [id], onDelete: SetNull)

  @@index([hospitalId])
  @@index([visitId])
  @@index([hospitalId, taskType, status])
  @@index([hospitalId, status])
}

enum VisitType {
  OPD
  EMERGENCY
  FOLLOW_UP
  IPD
}

enum VisitStatus {
  REGISTERED
  WAITING
  IN_CONSULTATION
  ACTIONS_PENDING
  IN_PROGRESS
  BILLING_PENDING
  COMPLETED
  CANCELLED
}

enum ActionType {
  PRESCRIPTION
  TEST
  PROCEDURE
  ADMISSION
  REFERRAL
  FOLLOW_UP
  CONSULTATION_NOTE
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY / STOCK / SUPPLIER / PURCHASE
// ─────────────────────────────────────────────────────────────────────────────

model StockBatch {
  id            String          @id @default(uuid())
  hospitalId    String
  itemId        String
  batchNumber   String?
  quantity      Int
  remainingQty  Int
  purchasePrice Float
  sellingPrice  Float?
  expiryDate    DateTime?
  supplierId    String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  item          InventoryItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplier      Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  hospital      Hospital        @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  movements     StockMovement[]

  @@index([hospitalId])
  @@index([itemId])
  @@index([expiryDate])
}

model StockMovement {
  id          String         @id @default(uuid())
  hospitalId  String
  itemId      String
  batchId     String?
  type        String
  quantity    Int
  source      String
  referenceId String?
  notes       String?        @db.Text
  performedBy String?
  createdAt   DateTime       @default(now())
  item        InventoryItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  batch       StockBatch?    @relation(fields: [batchId], references: [id], onDelete: SetNull)
  hospital    Hospital       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([itemId])
  @@index([batchId])
  @@index([type])
}

model Supplier {
  id                  String       @id @default(uuid())
  hospitalId          String
  name                String
  code                String?
  contactPerson       String?
  designation         String?
  phone               String?
  altPhone            String?
  email               String?
  address1            String?      @db.Text
  address2            String?      @db.Text
  city                String?
  state               String?
  pincode             String?
  country             String?      @default("India")
  gstNumber           String?
  panNumber           String?
  drugLicense         String?
  fssaiLicense        String?
  bankName            String?
  accountNumber       String?
  ifscCode            String?
  upiId               String?
  paymentTerms        String?      @default("Immediate")
  creditLimit         Float        @default(0)
  openingBalance      Float        @default(0)
  preferredPaymentMode String?     @default("Bank Transfer")
  categoriesSupplied  String?      @db.Text
  brandAssociations   String?      @db.Text
  deliveryLeadTime    Int          @default(0)
  status              String       @default("Active")
  isPreferred         Boolean      @default(false)
  isBlacklisted       Boolean      @default(false)
  notes               String?      @db.Text
  specialInstructions String?      @db.Text
  documents           String?      @db.Text
  isActive            Boolean      @default(true)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  hospital            Hospital     @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  purchases           Purchase[]
  stockBatches        StockBatch[]

  @@index([hospitalId])
}

model Purchase {
  id          String         @id @default(uuid())
  hospitalId  String
  supplierId  String
  purchaseNo  String
  totalAmount Float
  status      String
  notes       String?        @db.Text
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  supplier    Supplier       @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  hospital    Hospital       @relation(fields: [hospitalId], references: [id], onDelete: Cascade)
  items       PurchaseItem[]

  @@unique([hospitalId, purchaseNo])
  @@index([hospitalId])
  @@index([supplierId])
}

model PurchaseItem {
  id          String        @id @default(uuid())
  hospitalId  String
  purchaseId  String
  itemId      String
  quantity    Int
  price       Float
  batchNumber String?
  expiryDate  DateTime?
  purchase    Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  hospital    Hospital      @relation(fields: [hospitalId], references: [id], onDelete: Cascade)

  @@index([hospitalId])
  @@index([purchaseId])
  @@index([itemId])
}
